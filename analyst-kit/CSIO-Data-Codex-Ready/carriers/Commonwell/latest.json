      },
      "BldgProtectionConverter": {
        "inheritsFrom": "V043.Generic",
        "overrides": "ConvertDistanceToHydrant (300m threshold), ConvertFireProtectionClassCd (P/U classification based on firehall distance, numeric distance, hydrant proximity)",
