  "carrierSpecificBehavior": {
    "alarmAndSecurity": {
      "description": "Edge overrides IsLocal() for alarm classification. If AlarmDescCd = NoneNotApplicable, returns false. If AlarmDescCd = LocalAlarm, returns true. Otherwise falls through to generic base.",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    },
    "creditScoreProcessing": {
      "description": "Edge has custom CreditScoreInfoConverter for both directions (FrameworkToCsio and CsioToFramework). Outbound: sends CreditScore, CreditScoreDt, and ReferenceNumber. Inbound: parses into InsuranceCompanyCode.EdgeMutual credit scores collection. Only writes output if both CreditScore and CreditScoreDt are present.",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    },
    "dwellInspectionValuation": {
      "description": "Edge overrides ConvertDwellInspectionValuation to process DwellInspectionValuation as a non-collection (single item) rather than collection. Generic base expects DwellInspectionValuationCollection.",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    },
    "heatingUnitFiltering": {
      "description": "Edge filters out heating units where HeatingUnitCd = None. Generic base does not filter.",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    },
    "drivingRecordProtector": {
      "description": "Edge custom PcCoverageConverter maps AccidentRatingWaiver to DrivingRecordProtectorClaims endorsement. Sets DrivingRecordProtectorYesNo = True and optionally DrivingRecordProtectorClaimsEffectiveSince from EffectiveDt. Edge does NOT require effective date (unlike generic which might).",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    },
    "paymentPlan": {
      "description": "Edge overrides PaymentPlanConverter: Annual frequency maps to PaymentPlan.One (single payment). Other frequencies fall through to generic base.",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    },
    "lossLocation": {
      "description": "Edge overrides LossLocationCdConverter with custom mappings: ALocationNumber -> PrincipalResidence, InsuredAddress -> PrincipalResidence, PremisesAddress -> SecondaryResidence, Other -> SeasonalDwelling. Does NOT fall through to generic base (returns False for unknown codes).",
      "version": "v043",
      "availableIn": ["v043", "V128"]
    }
  },
